{
  "name": "markdown-explorer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "dist": "npm run build && electron-builder",
    "pack": "npm run build && electron-builder --dir",
    "install:local": "npm run pack && (osascript -e 'quit app \"markdown-explorer\"' || true) && rm -rf /Applications/markdown-explorer.app && cp -R release/mac-arm64/markdown-explorer.app /Applications/ && xattr -dr com.apple.quarantine /Applications/markdown-explorer.app && open /Applications/markdown-explorer.app",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/noto-sans-jp": "^5.2.9",
    "cytoscape": "^3.34.0",
    "highlight.js": "^11.11.1",
    "idb-keyval": "^6.2.4",
    "markdown-it": "^14.2.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^1.0.0"
  },
  "build": {
    "appId": "com.markdownexplorer.app",
    "productName": "markdown-explorer",
    "files": [
      "dist",
      "dist-electron"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg",
      "identity": null,
      "icon": "build/icon.png",
      "extendInfo": {
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Markdown Document",
            "CFBundleTypeRole": "Viewer",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": [
              "net.daringfireball.markdown",
              "public.plain-text"
            ]
          }
        ],
        "UTImportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "net.daringfireball.markdown",
            "UTTypeDescription": "Markdown Document",
            "UTTypeConformsTo": [
              "public.plain-text"
            ],
            "UTTypeTagSpecification": {
              "public.filename-extension": [
                "md",
                "markdown",
                "mdown",
                "mkd"
              ],
              "public.mime-type": [
                "text/markdown"
              ]
            }
          }
        ]
      }
    }
  }
}
